DATABASE_URL=postgresql+psycopg://neondb_owner:password@ep-example.us-east-2.aws.neon.tech/budgetbuddy?sslmode=require
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_TOKEN_TTL_SECONDS=2592000
# Short replay grace window for concurrent refresh requests; set to 0 to disable grace handling.
REFRESH_GRACE_PERIOD_SECONDS=30
REFRESH_COOKIE_NAME=bb_refresh
REFRESH_COOKIE_PATH=/api/auth
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=
AUTH_REGISTER_RATE_LIMIT_PER_MINUTE=5
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=30
BUDGETBUDDY_CORS_ORIGINS=http://localhost:5173
BOOTSTRAP_ALLOW_PROD=false
BOOTSTRAP_CREATE_DEMO_USER=false
BOOTSTRAP_SEED_MINIMAL_DATA=true
BOOTSTRAP_DEMO_USERNAME=demo_user
BOOTSTRAP_DEMO_PASSWORD=demo-password-123
BOOTSTRAP_DEMO_CURRENCY_CODE=USD

# Web Push (required for /api/push/vapid-public-key and delivery)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_CONTACT=mailto:tu-correo@dominio.com

# Non-production only: required header token for POST /api/push/test
PUSH_TEST_TOKEN=change-me-local-push-test-token
